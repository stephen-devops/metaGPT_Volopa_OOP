sequenceDiagram
    participant C as Client
    participant MW as Oauth2UserClient
    participant UPC as UserFeaturePermissionController
    participant UPS as UserFeaturePermissionService
    participant Policy as UserFeaturePermissionPolicy
    participant UPM as UserFeaturePermission
    C->>MW: POST /api/v1/user-feature-permissions
    MW->>UPC: authenticated request
    UPC->>Policy: authorize('create', UserFeaturePermission)
    Policy-->>UPC: authorized
    UPC->>UPS: createPermission(requestData)
    UPS->>UPM: create permission record
    UPM-->>UPS: UserFeaturePermission instance
    UPS-->>UPC: created permission
    UPC-->>C: 201 UserFeaturePermissionResource

sequenceDiagram
    participant C as Client
    participant MW as Oauth2UserClient
    participant PEC as PocketExpenseController
    participant PES as PocketExpenseService
    participant FXS as PocketExpenseFXService
    participant Policy as PocketExpensePolicy
    participant PE as PocketExpense
    C->>MW: POST /api/v1/pocket-expenses (with currency data)
    MW->>PEC: authenticated request
    PEC->>Policy: authorize('create', PocketExpense)
    Policy-->>PEC: authorized
    PEC->>FXS: convertExpenseAmount(requestData, clientId)
    FXS->>FXS: getWalletBaseCurrency(clientId)
    FXS->>FXS: getFXRate(fromCurrency, toCurrency, date)
    FXS->>FXS: calculateConvertedAmount(amount, rate, commission)
    FXS-->>PEC: converted amount data
    PEC->>PES: createExpense(convertedData)
    PES->>PE: create expense record
    PE-->>PES: PocketExpense instance
    PES-->>PEC: created expense
    PEC-->>C: 201 PocketExpenseResource

sequenceDiagram
    participant C as Client
    participant MW as Oauth2UserClient
    participant PUC as PocketExpenseUploadController
    participant CSV as PocketExpenseCSVValidator
    participant DB as Database
    participant Queue as Queue
    participant Job as ProcessExpenseUpload
    C->>MW: POST /api/uploads/pocket-expense/csv
    MW->>PUC: authenticated request with CSV file
    PUC->>PUC: basic file validation (size, type)
    PUC->>DB: create PocketExpenseFileUpload (status=uploaded)
    DB-->>PUC: upload record created
    PUC->>CSV: validate(filePath, targetUserId, clientId, adminId)
    CSV->>CSV: preloadReferenceData(clientId)
    CSV->>CSV: validateHeaders(headers)
    CSV->>CSV: validateRow(row, lineNumber) for each row
    CSV-->>PUC: validation result
    alt validation failed
        PUC->>DB: update upload (status=validation_failed, errors)
        PUC-->>C: 422 validation errors
    else validation passed
        PUC->>DB: bulk insert to PocketExpenseUploadsData (status=pending)
        PUC->>DB: update upload (status=processing)
        PUC->>Queue: dispatch ProcessExpenseUpload(uploadId)
        PUC-->>C: 200 success response
        Queue->>Job: handle()
        Job->>Job: syncExpenseBatch() in batches of 100
        Job->>DB: update upload (status=completed)
    end
