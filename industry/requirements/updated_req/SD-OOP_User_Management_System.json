{
  "document": {
    "title": "OOP User Management System",
    "type": "software_design_specification",
    "module": "User Management & Permissions",
    "origin": "new"
  },
  "hierarchy": {
    "description": "Primary Admin has full access to all users and can delegate management rights to Admin Users, who then manage a subset of users.",
    "origin": "new",
    "tree": {
      "role": "Primary Admin (X)",
      "capabilities": [
        "Full access to all users (A, B, C, Y, Z...)",
        "Can delegate management rights to Admin User (Y)"
      ],
      "delegated": {
        "role": "Admin User (Y)",
        "capabilities": [
          "Manages subset of users (A, B, C...)"
        ]
      }
    }
  },
  "er_diagram": {
    "entities": [
      { "name": "features", "origin": "existing" },
      { "name": "users", "origin": "existing" },
      { "name": "clients", "origin": "existing" },
      { "name": "user_feature_permission", "origin": "new" },
      { "name": "oop_expenses", "origin": "new" }
    ],
    "relationships": [
      { "from": "features", "to": "user_feature_permission", "type": "one_to_many", "label": "has", "origin": "new" },
      { "from": "users", "to": "user_feature_permission", "type": "one_to_many", "label": "has", "origin": "new" },
      { "from": "clients", "to": "user_feature_permission", "type": "one_to_many", "label": "has", "origin": "new" },
      { "from": "users", "to": "oop_expenses", "type": "one_to_many", "label": "creates", "origin": "new" },
      { "from": "clients", "to": "oop_expenses", "type": "one_to_many", "label": "contains", "origin": "new" },
      { "from": "users", "to": "oop_expenses", "type": "one_to_many", "label": "approves", "origin": "new" }
    ]
  },
  "permission_metrics": [
    {
      "role": "Primary Administrator",
      "origin": "existing",
      "default_permissions": {
        "own_expenses": ["create", "view", "update", "delete", "approve"],
        "all_users_expenses": ["create", "view", "update", "approve"],
        "management_rights": ["grant", "revoke"],
        "origin": "new"
      }
    },
    {
      "role": "Administrator",
      "origin": "existing",
      "default_permissions": {
        "own_expenses": ["create", "view", "update", "delete", "approve"],
        "all_users_expenses": [],
        "management_rights": [],
        "origin": "new"
      },
      "with_management_rights": {
        "managed_users_expenses": ["create", "view", "update", "approve"],
        "management_rights": ["grant", "revoke"],
        "origin": "new"
      }
    },
    {
      "role": "Business User",
      "origin": "existing",
      "default_permissions": {
        "own_expenses": ["create", "view", "update", "delete"],
        "all_users_expenses": [],
        "management_rights": [],
        "approval_rights": [],
        "origin": "new"
      },
      "with_management_rights": {
        "managed_users_expenses": ["create", "view", "update"],
        "approval_rights": [],
        "origin": "new"
      }
    },
    {
      "role": "Card User",
      "origin": "existing",
      "default_permissions": {
        "own_expenses": ["create", "view", "update", "delete"],
        "all_users_expenses": [],
        "management_rights": [],
        "approval_rights": [],
        "origin": "new"
      },
      "with_management_rights": {
        "managed_users_expenses": ["create", "view", "update"],
        "approval_rights": [],
        "origin": "new"
      }
    }
  ],
  "database_schema": {
    "tables": [
      {
        "name": "user_feature_permission",
        "origin": "new",
        "columns": [
          { "name": "id", "type": "BIGINT UNSIGNED", "constraints": ["AUTO_INCREMENT", "PRIMARY KEY"] },
          { "name": "user_id", "type": "BIGINT UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "client_id", "type": "BIGINT UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "feature_id", "type": "BIGINT UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "grantor_id", "type": "BIGINT UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "manager_user_id", "type": "BIGINT UNSIGNED", "constraints": ["NULL"] },
          { "name": "is_enabled", "type": "BOOLEAN", "default": true },
          { "name": "created_at", "type": "TIMESTAMP", "constraints": ["NULL"] },
          { "name": "updated_at", "type": "TIMESTAMP", "constraints": ["NULL"] }
        ],
        "unique_keys": [
          { "name": "unique_user_feature", "columns": ["user_id", "client_id", "feature_id"] }
        ],
        "foreign_keys": [
          { "column": "user_id", "references": "users(id)", "on_delete": "CASCADE", "referenced_table_origin": "existing" },
          { "column": "client_id", "references": "clients(id)", "on_delete": "CASCADE", "referenced_table_origin": "existing" },
          { "column": "feature_id", "references": "features(id)", "on_delete": "CASCADE", "referenced_table_origin": "existing" },
          { "column": "grantor_id", "references": "users(id)", "on_delete": "CASCADE", "referenced_table_origin": "existing" },
          { "column": "manager_user_id", "references": "users(id)", "on_delete": "CASCADE", "referenced_table_origin": "existing" }
        ]
      },
      {
        "name": "oop_expenses",
        "origin": "new",
        "columns": [
          { "name": "id", "type": "BIGINT UNSIGNED", "constraints": ["AUTO_INCREMENT", "PRIMARY KEY"] },
          { "name": "user_id", "type": "BIGINT UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "client_id", "type": "BIGINT UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "date", "type": "DATE", "constraints": ["NOT NULL"] },
          { "name": "merchant_name", "type": "VARCHAR(255)", "constraints": ["NOT NULL"] },
          { "name": "description", "type": "TEXT", "constraints": ["NULL"] },
          { "name": "transaction_type", "type": "ENUM('atm_withdrawal','point_of_sale','fee_charges','refund')", "constraints": ["NOT NULL"] },
          { "name": "currency", "type": "VARCHAR(3)", "constraints": ["NOT NULL"] },
          { "name": "amount", "type": "DECIMAL(10,2)", "constraints": ["NOT NULL"] },
          { "name": "merchant_address", "type": "TEXT", "constraints": ["NULL"] },
          { "name": "country", "type": "VARCHAR(100)", "constraints": ["NOT NULL"] },
          { "name": "source", "type": "VARCHAR(100)", "constraints": ["NOT NULL"] },
          { "name": "category", "type": "VARCHAR(100)", "constraints": ["NULL"] },
          { "name": "custom_fields", "type": "JSON", "constraints": ["NULL"] },
          { "name": "tracking_code_i", "type": "VARCHAR(100)", "constraints": ["NULL"] },
          { "name": "tracking_code_ii", "type": "VARCHAR(100)", "constraints": ["NULL"] },
          { "name": "project_id", "type": "VARCHAR(100)", "constraints": ["NULL"] },
          { "name": "vat", "type": "DECIMAL(10,2)", "constraints": ["NULL"] },
          { "name": "status", "type": "ENUM('pending','approved','rejected','in_review')", "default": "pending" },
          { "name": "approved_by", "type": "BIGINT UNSIGNED", "constraints": ["NULL"] },
          { "name": "approved_at", "type": "TIMESTAMP", "constraints": ["NULL"] },
          { "name": "receipt_path", "type": "VARCHAR(500)", "constraints": ["NULL"] },
          { "name": "notes", "type": "TEXT", "constraints": ["NULL"] },
          { "name": "created_at", "type": "TIMESTAMP", "constraints": ["NULL"] },
          { "name": "updated_at", "type": "TIMESTAMP", "constraints": ["NULL"] }
        ],
        "foreign_keys": [
          { "column": "user_id", "references": "users(id)", "on_delete": "CASCADE", "referenced_table_origin": "existing" },
          { "column": "client_id", "references": "clients(id)", "on_delete": "CASCADE", "referenced_table_origin": "existing" },
          { "column": "approved_by", "references": "users(id)", "on_delete": "SET NULL", "referenced_table_origin": "existing" }
        ]
      }
    ],
    "notes": "Keep an audit log of granting, enable and disable of permissions"
  },
