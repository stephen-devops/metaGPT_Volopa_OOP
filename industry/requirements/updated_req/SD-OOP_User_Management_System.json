  },
  "access_control_flow": {
    "origin": "new",
    "service_enablement_flow": [
      "Sales/Ops Management enables Expense via Admin.Volopa",
      "System validates client has card services active",
      "Email notification sent to client Primary Admin",
      "Default permission applied automatically"
    ],
    "default_permissions_once_enabled": {
      "origin": "new",
      "all_users": {
        "description": "ALL USERS (card user, business user, administrator, primary administrator) under the client",
        "permissions": ["Add own expense", "Edit own expense", "View own expense"]
      },
      "administrator": {
        "description": "Administrator can do all above and",
        "additional_permissions": ["Approve own expense"]
      },
      "primary_administrator": {
        "description": "Primary Administrator can do all above and",
        "additional_permissions": [
          "Add expense for All",
          "Edit expense for All",
          "View expense for all",
          "Approve expense for all",
          "Grant access to others"
        ]
      }
    },
    "granting_managing_rights": {
      "origin": "new",
      "who_can_grant": [
        {
          "role": "Primary Administrator and Administrator",
          "method": "Web App: Settings > Manage Users",
          "method_origin": "existing"
        },
        {
          "role": "Volopa Admin(1)",
          "method": "Admin.Volopa: User accounts page",
          "method_origin": "existing"
        }
      ],
      "note": "Managing access can be given to any user irrespective of the role"
    },
    "managing_user_once_rights_granted": {
      "origin": "new",
      "card_user_and_business_user": {
        "permissions": [
          "Add expense for the managed user",
          "Edit expense for the managed user",
          "View expense for the managed user"
        ]
      },
      "administrator": {
        "permissions": [
          "Add expense for the managed user",
          "Edit expense for the managed user",
          "View expense for the managed user",
          "Approve expense",
          "Can grant access to others (can only grant access to managed users)"
        ]
      }
    },
    "revoking_managing_rights": {
      "origin": "new",
      "who_can_revoke": [
        {
          "role": "Primary Administrator",
          "method": "Web App: Settings > Manage Users",
          "method_origin": "existing"
        },
        {
          "role": "Volopa Admin(1)",
          "method": "Admin.Volopa: User accounts page",
          "method_origin": "existing"
        }
      ],
      "revocation_effect": "If managing right is revoked, the user loses access to add, edit, view / approve access to that specific user. Until another manager is set the base user is managed by Primary administrator."
    }
  }
}
