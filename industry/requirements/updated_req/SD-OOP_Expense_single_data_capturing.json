{
  "document": {
    "title": "OOP Expense Single Data Capturing",
    "type": "software_design_specification",
    "module": "Out-of-Pocket Expense Single Entry",
    "origin": "new"
  },
  "database_schema": {
    "tables": [
      {
        "name": "opt_pocket_expense_type",
        "origin": "new",
        "description": "Lookup table for expense/transaction types",
        "columns": [
          { "name": "id", "type": "INT(11) UNSIGNED", "constraints": ["NOT NULL", "AUTO_INCREMENT"] },
          { "name": "option", "type": "VARCHAR(128)", "constraints": ["NOT NULL"], "default": "" },
          { "name": "amount_sign", "type": "ENUM('positive','negative')", "default": "negative" }
        ],
        "primary_key": "id",
        "seed_data": [
          { "option": "ATM Withdrawal", "amount_sign": "negative" },
          { "option": "Point of Sale", "amount_sign": "negative" },
          { "option": "Fee & Charges", "amount_sign": "negative" },
          { "option": "Refund from Merchant", "amount_sign": "positive" }
        ]
      },
      {
        "name": "pocket_expense_source_client_config",
        "origin": "new",
        "description": "Client-specific and global expense source configuration",
        "columns": [
          { "name": "id", "type": "INT(10) UNSIGNED", "constraints": ["NOT NULL", "AUTO_INCREMENT"] },
          { "name": "uuid", "type": "VARCHAR(36)", "default": "NULL" },
          { "name": "client_id", "type": "INT(10) UNSIGNED", "default": "NULL" },
          { "name": "name", "type": "VARCHAR(100)", "constraints": ["NOT NULL"] },
          { "name": "is_default", "type": "TINYINT(1) UNSIGNED", "constraints": ["NOT NULL"], "default": 0 },
          { "name": "deleted", "type": "TINYINT(1) UNSIGNED", "constraints": ["NOT NULL"], "default": 0 },
          { "name": "delete_time", "type": "DATETIME", "default": "NULL" },
          { "name": "create_time", "type": "DATETIME", "default": "NULL" },
          { "name": "update_time", "type": "DATETIME", "default": "NULL" }
        ],
        "primary_key": "id",
        "unique_keys": [
          { "name": "oop_expense_source_client_name_unique", "columns": ["client_id", "name"] }
        ],
        "foreign_keys": [
          { "name": "oop_expense_source_client_id_foreign", "column": "client_id", "references": "client(id)", "referenced_table_origin": "existing" }
        ]
      },
      {
        "name": "pocket_expense",
        "origin": "new",
        "description": "Main table for out-of-pocket expense records",
        "columns": [
          { "name": "id", "type": "INT(10) UNSIGNED", "constraints": ["NOT NULL", "AUTO_INCREMENT"] },
          { "name": "uuid", "type": "VARCHAR(36)", "default": "NULL" },
          { "name": "user_id", "type": "INT(11) UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "client_id", "type": "INT(11) UNSIGNED", "default": "NULL" },
          { "name": "date", "type": "DATE", "constraints": ["NOT NULL"] },
          { "name": "merchant_name", "type": "VARCHAR(180)", "constraints": ["NOT NULL"] },
          { "name": "merchant_description", "type": "VARCHAR(255)", "default": "NULL" },
          { "name": "expense_type", "type": "INT(11) UNSIGNED", "default": "NULL" },
          { "name": "currency", "type": "CHAR(3)", "constraints": ["NOT NULL"] },
          { "name": "amount", "type": "DECIMAL(14,2)", "constraints": ["NOT NULL"], "default": "0.00" },
          { "name": "merchant_address", "type": "VARCHAR(500)", "default": "NULL" },
          { "name": "vat_amount", "type": "DECIMAL(12,2)", "default": "NULL" },
          { "name": "notes", "type": "TEXT", "default": "NULL" },
          { "name": "status", "type": "ENUM('draft','submitted','approved','rejected')", "default": "draft" },
          { "name": "created_by_user_id", "type": "INT(11)", "constraints": ["NOT NULL"] },
          { "name": "updated_by_user_id", "type": "INT(11) UNSIGNED", "default": "NULL" },
          { "name": "approved_by_user_id", "type": "INT(11) UNSIGNED", "default": "NULL" },
          { "name": "create_time", "type": "DATETIME", "default": "CURRENT_TIMESTAMP" },
          { "name": "update_time", "type": "DATETIME", "default": "NULL", "on_update": "CURRENT_TIMESTAMP" },
          { "name": "deleted", "type": "TINYINT(1) UNSIGNED", "constraints": ["NOT NULL"], "default": 0 },
          { "name": "delete_time", "type": "DATETIME", "default": "NULL" }
        ],
        "primary_key": "id",
        "indexes": [
          { "name": "pocket_expense_user_id_foreign", "column": "user_id" },
          { "name": "pocket_expense_client_id_foreign", "column": "client_id" },
          { "name": "pocket_expense_expense_type_foreign", "column": "expense_type" }
        ],
        "foreign_keys": [
          { "name": "pocket_expense_user_id_foreign", "column": "user_id", "references": "user(id)", "referenced_table_origin": "existing" },
          { "name": "pocket_expense_client_id_foreign", "column": "client_id", "references": "client(id)", "referenced_table_origin": "existing" },
          { "name": "pocket_expense_expense_type_foreign", "column": "expense_type", "references": "opt_pocket_expense_type(id)", "referenced_table_origin": "new" }
        ]
      },
      {
        "name": "pocket_expense_metadata",
        "origin": "new",
        "description": "Flexible metadata storage for pocket expenses (one record per type per expense)",
        "columns": [
          { "name": "id", "type": "INT(10) UNSIGNED", "constraints": ["NOT NULL", "AUTO_INCREMENT"] },
          { "name": "pocket_expense_id", "type": "INT(10) UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "metadata_type", "type": "ENUM('category','tracking_code_type_1','tracking_code_type_2','project','additional_field','file','expense_source')", "constraints": ["NOT NULL"] },
          { "name": "transaction_category_id", "type": "INT(10) UNSIGNED", "default": "NULL" },
          { "name": "tracking_code_id", "type": "INT(10) UNSIGNED", "default": "NULL" },
          { "name": "project_id", "type": "INT(10) UNSIGNED", "default": "NULL" },
          { "name": "file_store_id", "type": "INT(10) UNSIGNED", "default": "NULL" },
          { "name": "expense_source_id", "type": "INT(10) UNSIGNED", "default": "NULL" },
          { "name": "additional_field_id", "type": "INT(10) UNSIGNED", "default": "NULL" },
          { "name": "user_id", "type": "INT(11) UNSIGNED", "constraints": ["NOT NULL"] },
          { "name": "details_json", "type": "JSON", "default": "NULL" },
          { "name": "create_time", "type": "DATETIME", "default": "CURRENT_TIMESTAMP" },
          { "name": "update_time", "type": "DATETIME", "default": "NULL", "on_update": "CURRENT_TIMESTAMP" },
          { "name": "deleted", "type": "TINYINT(1) UNSIGNED", "constraints": ["NOT NULL"], "default": 0 },
          { "name": "delete_time", "type": "DATETIME", "default": "NULL" }
        ],
        "primary_key": "id",
        "unique_keys": [
          { "name": "metadata_category_unique", "columns": ["pocket_expense_id", "<category>", "deleted"] },
          { "name": "metadata_tracking_type_1_unique", "columns": ["pocket_expense_id", "metadata_type", "deleted"] },
          { "name": "metadata_tracking_type_2_unique", "columns": ["pocket_expense_id", "metadata_type", "deleted"] },
          { "name": "metadata_project_unique", "columns": ["pocket_expense_id", "metadata_type", "deleted"] },
          { "name": "metadata_source_unique", "columns": ["pocket_expense_id", "metadata_type", "deleted"] }
        ],
        "foreign_keys": [
          { "name": "metadata_expense_id_foreign", "column": "pocket_expense_id", "references": "pocket_expense(id)", "referenced_table_origin": "new" },
          { "name": "metadata_category_id_foreign", "column": "transaction_category_id", "references": "transaction_category(id)", "referenced_table_origin": "existing" },
          { "name": "metadata_tracking_code_id_foreign", "column": "tracking_code_id", "references": "tracking_codes(id)", "referenced_table_origin": "existing" },
          { "name": "metadata_project_id_foreign", "column": "project_id", "references": "configurable_projects(id)", "referenced_table_origin": "existing" },
          { "name": "metadata_file_store_id_foreign", "column": "file_store_id", "references": "file_store(id)", "referenced_table_origin": "existing" },
          { "name": "metadata_source_id_foreign", "column": "expense_source_id", "references": "pocket_expense_source_client_config(id)", "referenced_table_origin": "new" },
          { "name": "metadata_additional_field_id_foreign", "column": "additional_field_id", "references": "expense_additional_field(id)", "referenced_table_origin": "existing" },
          { "name": "metadata_user_id_foreign", "column": "user_id", "references": "user(id)", "referenced_table_origin": "existing" }
        ],
        "indexes": [
          { "name": "metadata_expense_id_index", "column": "pocket_expense_id" },
          { "name": "metadata_type_index", "column": "metadata_type" },
          { "name": "metadata_category_index", "column": "transaction_category_id" },
          { "name": "metadata_tracking_code_index", "column": "tracking_code_id" },
          { "name": "metadata_project_index", "column": "project_id" },
          { "name": "metadata_file_index", "column": "file_store_id" },
          { "name": "metadata_source_index", "column": "expense_source_id" }
        ]
      }
    ],
    "metadata_json_examples": {
      "origin": "new",
      "category": {
        "other": "Custom Software Development",
        "is_other": 1,
        "field_1_value": "Engineering Department",
        "field_2_value": "Project Alpha Budget"
      },
      "additional_field": {
        "value": "Client meeting and product demo"
      },
      "expense_source_custom": {
        "expense_source_other_value": "blah blah PayPal"
      },
      "tracking_code": {},
      "project": {},
      "file": {}
    }
  },
  "oop_expense_source": {
    "origin": "new",
    "default_and_global_source_setup": {
      "origin": "new",
      "on_client_oop_feature_enable": {
        "auto_create_defaults": ["Cash", "Corporate Card", "Personal Card"],
        "table": "oop_expense_source_client_config",
        "trigger": "When OOP feature is enabled"
      },
      "global_other": {
        "description": "Ensure a single global 'Other' record exists in the master table (client_id = NULL). Add into the migration.",
        "restrictions": "'Other' is not deletable or editable by clients"
      }
    },
    "dropdown_display": {
      "origin": "new",
      "items": [
        { "type": "client_specific", "filter": "client_id = current_client AND deleted = 0" },
        { "type": "global", "filter": "client_id IS NULL" }
      ]
    },
    "expense_submission": {
      "origin": "new",
      "non_other_source": {
        "save": "expense_source_id only"
      },
      "other_source": {
        "save_expense_source_id": "ID of global 'Other' record",
        "save_custom_text": "Save user input text into custom_source_text field"
      }
    },
    "client_config_behaviour": {
      "origin": "new",
      "max_active_sources_per_client": 20,
      "soft_delete": {
        "mechanism": "Set deleted = 1",
        "deleted_sources_behavior": [
          "Remain visible on historical expense details",
          "Are excluded from future dropdowns"
        ]
      },
      "validation_rules": [
        "Prevent creation of more than 20 active sources per client",
        "Enforce unique source names per client (client_id, name)"
      ]
    }
  },
  "currency_conversion": {
    "origin": "existing",
    "description": "FX conversion for out-of-pocket expenses",
    "query_description": "Joins prepaid_card -> prepaid_card_tier_map -> account_tier -> account -> currency tables to determine base currencies",
    "referenced_tables": [
      { "name": "prepaid_card", "origin": "existing" },
      { "name": "prepaid_card_tier_map", "origin": "existing" },
      { "name": "account_tier", "origin": "existing" },
      { "name": "account", "origin": "existing" },
      { "name": "currency", "origin": "existing" }
    ],
    "returned_fields": [
      "client_id",
      "account_base_currency_id",
      "account_base_currency_code",
      "tier_base_currency_id",
      "tier_base_currency_code",
      "card_currency"
    ],
    "filter_conditions": [
      "client_id filter",
      "master_virtual_card = 1",
      "deleted = 0"
    ]
  },
  "fx_conversion_flow": {
    "origin": "new",
    "step_1_user_input": {
      "name": "User Input",
      "origin": "new",
      "flow": [
        "User inputs Date / Currency / Amount",
        "Check: All Required Fields Entered?",
        "If No -> back to input",
        "If Yes -> 2s Debounce",
        "Check: Debounce Done?",
        "If No -> back to input",
        "If Yes -> Trigger FX API Call"
      ]
    },
    "step_2_fx_calculation": {
      "name": "FX Calculation",
      "origin": "unclear",
      "origin_note": "The FX calculation logic (rates, commission) likely uses existing platform FX infrastructure, but the specific flow with wallet-ccy-value endpoint and 30-day lookback may be new to OOP",
      "flow": [
        "Identify Wallet Base Currency (via /wallet-ccy-value endpoint)",
        "Get Dated FX Rate (max 30-day lookback)",
        "Check: FX Rate Found?",
        "If No -> Return 'No FX Available'",
        "If Yes -> Get Client Commission",
        "Adjusted Rate = BaseRate x (1 - Comm%)",
        "Converted Amount = Amount x AdjustedRate",
        "Return Converted Amount"
      ],
      "referenced_infrastructure": [
        { "name": "/wallet-ccy-value endpoint", "origin": "existing" },
        { "name": "FX rates", "origin": "existing" },
        { "name": "Client commission", "origin": "existing" }
      ]
    },
    "step_3_frontend_save": {
      "name": "Frontend + Save",
      "origin": "new",
      "flow": [
        "Frontend populates Converted Amount Field",
        "Check: User Overrides Value?",
        "If Yes -> Store user_converted_amount",
        "If No -> Use API Value",
        "Form Submit",
        "Backend Recalculate FX",
        "Save pocket_expense"
      ]
    }
  }
}
